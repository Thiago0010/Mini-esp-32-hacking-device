void drawScreen_DeauthPortal(void) {
    tft.fillScreen(0x0);
    tft.fillRect(-18, -8, 347, 270, 0x7D10); // Fundo padrão
    
    // Header
    tft.setTextColor(0xFFFF);
    tft.setTextSize(2);
    tft.drawString("Deauth Portal", 82, 11);
    
    // Painel Principal
    tft.fillRoundRect(32, 40, 265, 160, 8, 0x53EB);
    
    // Status do Ataque
    tft.setTextSize(1);
    tft.setCursor(45, 60);
    tft.print("Status: ");
    tft.setTextColor(isAttacking ? 0xF800 : 0x07E0); // Vermelho se atacando, verde se idle
    tft.print(isAttacking ? "ATIVO" : "IDLE");
    
    // Informações do Alvo
    tft.setTextColor(0xFFFF);
    tft.setCursor(45, 85);
