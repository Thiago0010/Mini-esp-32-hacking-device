  ballX = SCREEN_W / 2;
  ballY = PONG_FIELD_TOP + 20;
  ballVX = 2.2;
  ballVY = 2.0;
  pongScore = 0;
  pongMisses = 0;
  prevPaddleX = -1;
  prevBallX = -1;
  prevBallY = -1;

  drawPongScore();
}

void updatePongGame() {
  int tx = 0, ty = 0, tz = 0;
  lerTouchTotalmenteIsolado(tx, ty, tz);

  if (tz > 300) {
    int screenX = map(tx, TOUCH_MIN_X, TOUCH_MAX_X, 0, SCREEN_W);
    int screenY = map(ty, TOUCH_MIN_Y, TOUCH_MAX_Y, 0, SCREEN_H);
    screenX = constrain(screenX, 0, SCREEN_W);
    screenY = constrain(screenY, 0, SCREEN_H);

    if (screenX >= EXIT_BTN_X && screenX <= EXIT_BTN_X + EXIT_BTN_W &&
        screenY >= EXIT_BTN_Y && screenY <= EXIT_BTN_Y + EXIT_BTN_H) {
      currentState = STATE_MENU;
      renderMenu();
      delay(250);
      return;
    }

    paddleX = constrain(screenX - PADDLE_WIDTH / 2, PONG_FIELD_LEFT, PONG_FIELD_RIGHT - PADDLE_WIDTH);
  }

  if (prevPaddleX >= 0) {
    tft.fillRect(prevPaddleX, PADDLE_Y, PADDLE_WIDTH, PADDLE_HEIGHT, COLOR_BG);
  }
  if (prevBallX >= 0) {
    tft.fillRect((int)prevBallX, (int)prevBallY, BALL_SIZE, BALL_SIZE, COLOR_BG);
  }

  ballX += ballVX;
  ballY += ballVY;

  if (ballX <= PONG_FIELD_LEFT || ballX + BALL_SIZE >= PONG_FIELD_RIGHT) {
    ballVX = -ballVX;
    ballX = constrain(ballX, (float)PONG_FIELD_LEFT, (float)(PONG_FIELD_RIGHT - BALL_SIZE));
  }
  if (ballY <= PONG_FIELD_TOP) {
    ballVY = -ballVY;
    ballY = PONG_FIELD_TOP;
  }

  if (ballVY > 0 && ballY + BALL_SIZE >= PADDLE_Y && ballY + BALL_SIZE <= PADDLE_Y + PADDLE_HEIGHT + 6) {
    if (ballX + BALL_SIZE >= paddleX && ballX <= paddleX + PADDLE_WIDTH) {
      float hitPos = ((ballX + BALL_SIZE / 2.0) - paddleX) / (float)PADDLE_WIDTH;
      ballVY = -abs(ballVY) * 1.03;
      ballVX += (hitPos - 0.5) * 2.5;
      ballVX = constrain(ballVX, -6.0f, 6.0f);
      ballVY = constrain(ballVY, -6.0f, -1.5f);
      pongScore++;
      drawPongScore();
    }
  }

  if (ballY > PONG_FIELD_BOTTOM) {
    pongMisses++;
    drawPongScore();
    ballX = SCREEN_W / 2;
    ballY = PONG_FIELD_TOP + 20;
    ballVX = 2.2;
    ballVY = 2.0;
  }

  tft.fillRect(paddleX, PADDLE_Y, PADDLE_WIDTH, PADDLE_HEIGHT, COLOR_PRIMARY);
  tft.fillRect((int)ballX, (int)ballY, BALL_SIZE, BALL_SIZE, COLOR_TEXT);

  prevPaddleX = paddleX;
  prevBallX = ballX;
  prevBallY = ballY;
}

