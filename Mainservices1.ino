void enterWifiAnalyser() {
  currentState = STATE_WIFI_ANALYSER;
  wifiAnalyserPage = 0;  // começa na primeira página

  tft.fillScreen(COLOR_BG);
  tft.setTextColor(COLOR_WARN);
  tft.setTextSize(1);
  tft.setCursor(10, 100);
  tft.print("Escaneando redes...");

  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  delay(100);
  WiFi.scanDelete();
  wifiNetworksFound = WiFi.scanNetworks();


  // Preenche o array _networks
  for (int i = 0; i < wifiNetworksFound && i < 16; i++) {
    Network[i].ssid = WiFi.SSID(i);
    Network[i].ch   = WiFi.channel(i);
    Network[i].rssi = WiFi.RSSI(i);
    Network[i].enc  = WiFi.encryptionType(i);
  }


  renderWifiAnalyserScreen();
  
}


void renderWifiAnalyserScreen() {
  drawScreen_WifiAnalyser();

  tft.setTextColor(0xFFFF);
  tft.setTextSize(1);
  tft.setCursor(69, 46);
  if (wifiNetworksFound <= 0) {
    tft.print("Nenhuma rede encontrada");
  } else {
    tft.printf("%d redes encontradas | Pagina %d", wifiNetworksFound, wifiAnalyserPage + 1);
  }

  int ssidY[3] = {69, 113, 159};
  int chY[3]   = {86, 129, 177};

  // Calcula o índice inicial da página atual (3 redes por página)
  int startIdx = wifiAnalyserPage * 3;

  // Mostra até 3 redes a partir do índice start
  for (int i = 0; i < 3 && (startIdx + i) < wifiNetworksFound; i++) {
    int networkIdx = startIdx + i;
    
    tft.setTextColor(0xFB0A);
    tft.setCursor(55, ssidY[i]);
    String ssid = WiFi.SSID(networkIdx);
    if (ssid.length() > 18) ssid = ssid.substring(0, 18) + "..";
    tft.print(ssid);

    tft.setTextColor(0xFFFF);
    tft.setCursor(48, chY[i]);
    tft.printf("Ch:%2d %ddBm %s",
                WiFi.channel(networkIdx), WiFi.RSSI(networkIdx),
                encTypeStr(WiFi.encryptionType(networkIdx)).c_str());
  }
}

