    tft.fillRoundRect(80, 140, 160, 40, 8, 0xCD68);
    tft.setTextColor(0xFFFF);
    tft.setCursor(120, 153);
    tft.print(isAttacking ? "PARAR ATAQUE" : "INICIAR ATAQUE");
}

